{
  "name": "ferry-services",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @ferry-services/api",
    "dev:web": "npm run dev -w @ferry-services/web",
    "build": "npm run build -w @ferry-services/web && node scripts/sync-web-assets.mjs && npm run build -w @ferry-services/api",
    "typecheck": "npm run typecheck -w @ferry-services/web && npm run typecheck -w @ferry-services/api",
    "test": "npm test -w @ferry-services/web && npm test -w @ferry-services/api",
    "start": "npm run start -w @ferry-services/api",
    "migrate": "npm run migrate -w @ferry-services/api",
    "scrape": "npm run scrape -w @ferry-services/api",
    "fetch:weather": "npm run fetch:weather -w @ferry-services/api",
    "fetch:vessels": "npm run fetch:vessels -w @ferry-services/api",
    "fetch:rail": "npm run fetch:rail -w @ferry-services/api",
    "fetch:timetable-documents": "npm run fetch:timetable-documents -w @ferry-services/api",
    "generate:offline-snapshot": "npm run generate:offline-snapshot -w @ferry-services/api",
    "ingest:transxchange": "npm run ingest:transxchange -w @ferry-services/api"
  }
}
