{
  "name": "ferry-services",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "start": "node --import ./dist/shared/sentry.js dist/app/server.js",
    "test": "NODE_ENV=test tsx --test \"test/**/*.test.ts\" \"src/**/*.test.ts\"",
    "migrate": "node dist/db/migrate.js",
    "scrape": "node --import ./dist/shared/sentry.js dist/features/service-status/fetcher.js",
    "fetch:weather": "node --import ./dist/shared/sentry.js dist/features/weather/fetcher.js",
    "fetch:vessels": "node --import ./dist/shared/sentry.js dist/features/vessels/fetcher.js",
    "fetch:rail": "node --import ./dist/shared/sentry.js dist/features/rail/fetcher.js",
    "fetch:timetable-documents": "node --import ./dist/shared/sentry.js dist/features/timetable-documents/fetcher.js",
    "generate:offline-snapshot": "node --import ./dist/shared/sentry.js dist/features/offline-snapshot/generator.js",
    "ingest:transxchange": "node --import ./dist/shared/sentry.js dist/features/transxchange/ingester.js"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@sentry/node": "^10.54.0",
    "@sinclair/typebox": "^0.34.49",
    "basic-ftp": "^6.0.1",
    "better-sqlite3": "^12.10.0",
    "cycletls": "^2.0.5",
    "dotenv": "^17.4.2",
    "fastify": "^5.3.0",
    "google-auth-library": "^10.6.2",
    "marked": "^18.0.4",
    "node-html-parser": "^7.1.0",
    "pino": "^10.3.1",
    "yauzl": "^3.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/yauzl": "^2.10.3",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
