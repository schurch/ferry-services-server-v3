{
  "name": "ferry-services-server-v3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/api/server.js",
    "test": "node --test",
    "migrate": "node dist/db/migrate.js",
    "scrape": "node dist/jobs/scraper.js",
    "fetch:weather": "node dist/jobs/weather-fetcher.js",
    "fetch:vessels": "node dist/jobs/vessel-fetcher.js"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@sinclair/typebox": "^0.34.49",
    "better-sqlite3": "^11.10.0",
    "cycletls": "^2.0.5",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.0",
    "google-auth-library": "^9.15.1",
    "marked": "^18.0.3",
    "node-html-parser": "^7.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
