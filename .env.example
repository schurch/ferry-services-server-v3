NODE_ENV=development
HOST=127.0.0.1
PORT=4322
TRUST_PROXY=false
LOG_LEVEL=info
DATABASE_PATH=./data/ferry-services.sqlite3
OPENWEATHERMAP_APPID=
GOOGLE_MAPS_API_KEY=
AIS_STREAM_API_KEY=
RAIL_DATA_API_KEY=
TRAVELLINE_FTP_ADDRESS=
TRAVELLINE_FTP_USERNAME=
TRAVELLINE_FTP_PASSWORD=

# Optional local notification summaries
OLLAMA_URL=
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_TIMEOUT_MS=60000

# Sentry
SERVER_SENTRY_DSN=
SCRAPER_SENTRY_DSN=
WEATHER_FETCHER_SENTRY_DSN=
VESSEL_FETCHER_SENTRY_DSN=
RAIL_DEPARTURE_FETCHER_SENTRY_DSN=
TIMETABLE_DOCUMENT_SCRAPER_SENTRY_DSN=
TRANSXCHANGE_INGESTER_SENTRY_DSN=
OFFLINE_SNAPSHOT_GENERATOR_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# APNs direct push
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY_PATH=
APNS_PRODUCTION=false

# FCM HTTP v1 direct push
FCM_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Docker deployment
APP_UID=1000
APP_GID=1000
